{
  "name": "PresetTask",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Task Name"
    },
    "category": {
      "type": "string",
      "title": "Category",
      "enum": [
        "Cleaning",
        "House Maintenance",
        "Bill Schedules"
      ]
    },
    "room": {
      "type": "string",
      "title": "Room",
      "enum": [
        "",
        "Kitchen",
        "Bathroom",
        "Bedroom",
        "Living Room",
        "Dining Room",
        "Garage",
        "Laundry Room",
        "Office",
        "Basement",
        "Attic",
        "Outdoor",
        "Whole House",
        "Any"
      ]
    },
    "frequency_days": {
      "type": "number",
      "title": "Frequency (Days)"
    },
    "difficulty": {
      "type": "string",
      "title": "Difficulty",
      "enum": [
        "Trivial",
        "Easy",
        "Medium",
        "Hard",
        "Very Hard"
      ],
      "default": "Easy"
    },
    "description": {
      "type": "string",
      "title": "Description"
    }
  },
  "required": [
    "name",
    "category",
    "frequency_days"
  ]
}