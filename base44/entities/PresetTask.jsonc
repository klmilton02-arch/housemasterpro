{
  "name": "PresetTask",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Task Name"
    },
    "category": {
      "type": "string",
      "title": "Room",
      "enum": [
        "Kitchen",
        "Full Bathroom",
        "Half Bathroom",
        "Bedroom",
        "Living Room",
        "Dining Room",
        "Garage",
        "Laundry Room",
        "Office",
        "Playroom",
        "Basement",
        "Attic",
        "Outdoor",
        "Whole House",
        "Any"
      ]
    },
    "task_type": {
      "type": "string",
      "title": "Type",
      "enum": [
        "Cleaning",
        "Maintenance",
        "Bills"
      ]
    },
    "frequency_days": {
      "type": "number",
      "title": "Frequency (Days)"
    },
    "difficulty": {
      "type": "string",
      "title": "Difficulty",
      "enum": [
        "Trivial",
        "Easy",
        "Medium",
        "Hard",
        "Very Hard"
      ],
      "default": "Easy"
    },
    "description": {
      "type": "string",
      "title": "Description"
    }
  },
  "required": [
    "name",
    "frequency_days"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}